# =============================================================================
# NYS Voter Pipeline - Environment Variables
# Copy to .env and fill in your credentials. Never commit .env to git.
# =============================================================================

# ── Local MySQL 8.4 ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_PORT=3306
# Legacy aliases (some scripts still reference these)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_PORT=3306

# ── Aiven Remote MySQL (for sync command) ────────────────────────────────────
AIVEN_HOST=
AIVEN_USER=avnadmin
AIVEN_PASSWORD=
AIVEN_PORT=3306
AIVEN_DB=nys_voter_tagging
AIVEN_SSL_CA=certs/ca.pem

# ── HubSpot CRM (for hubspot-sync command) ───────────────────────────────────
# Add one token per account: HUBSPOT_TOKEN_1, HUBSPOT_TOKEN_2, etc.
# HUBSPOT_TOKEN_1=pat-na1-xxxxxxxx

# ── Campaign Monitor (for cm-sync command) ───────────────────────────────────
# Add one API key per account: CM_API_KEY_1, CM_API_KEY_2, etc.
# CM_API_KEY_1=xxxxxxxx

# ── Meta / Facebook (for fb-donors and fb-audience commands) ─────────────────
# System User token from Meta Business Manager → Settings → System Users
# Must have ads_management permission.
# If left blank here, the fb-donors command will automatically fall back to
# reading these from D:/git/facebook-receipt-automation/.env
META_ACCESS_TOKEN=
# Comma-separated list of Business Manager IDs (find at business.facebook.com)
META_BUSINESS_IDS=
