# ── Meta / Facebook ──────────────────────────────
# System User access token from Meta Business Manager
META_ACCESS_TOKEN=your_meta_system_user_token

# Comma-separated Business Manager IDs (find in Business Settings > Business Info)
META_BUSINESS_IDS=111111111111,222222222222

# Graph API version (default: v21.0 — update when Meta releases a new version)
# META_API_VERSION=v21.0

# ── Google ───────────────────────────────────────
# Path to your Google service account credentials JSON
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json

# Google Sheet ID (from the sheet URL: docs.google.com/spreadsheets/d/{THIS_PART}/edit)
GOOGLE_SHEET_ID=your_google_sheet_id

# Gmail address to send from (must be delegated to the service account, OR use app password)
GMAIL_SENDER_EMAIL=you@yourdomain.com

# If using Gmail App Password instead of service account delegation:
GMAIL_APP_PASSWORD=

# Email to notify when a receipt fails to send (defaults to George@politikanyc.com)
# NOTIFY_EMAIL=George@politikanyc.com

# ── Schedule ─────────────────────────────────────
# When to run: daily, weekly, monthly
SCHEDULE_FREQUENCY=monthly

# Day of month (1-28) for monthly, day of week (monday-sunday) for weekly
SCHEDULE_DAY=1

# Time to run (24h format)
SCHEDULE_TIME=09:00

# ── Storage ──────────────────────────────────────
# Where to save downloaded receipts
RECEIPT_DOWNLOAD_DIR=receipts
