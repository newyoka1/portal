# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Aiven MySQL ────────────────────────────────────────────────────────────
# Local dev: include ssl_ca file path in the URL
DATABASE_URL=mysql+pymysql://avnadmin:PASSWORD@mysql-xxxx.aivencloud.com:PORT/email_approval?ssl_ca=certs/ca.pem
# Railway/production: omit ssl_ca from URL, paste ca.pem contents here instead
MYSQL_SSL_CA_CONTENT=

# ── Google Service Account (Gmail API — polling + sending notifications) ───
# Local dev: path to the service account JSON file
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/your-service-account.json
# Railway/production: paste the full JSON contents here instead
GOOGLE_SERVICE_ACCOUNT_JSON=
GMAIL_ADDRESS=support@politikanyc.com

# ── App ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
PORT=8000
APP_URL=http://localhost:8000

# ── Gmail polling ──────────────────────────────────────────────────────────
POLL_INTERVAL_MINUTES=5
GMAIL_SUBJECT_FILTER=subject:Test
